# Copy to `.env` and fill in the required secrets before `docker compose up`.
# `install-panel.sh` can also generate this file interactively.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=monitor
POSTGRES_DB=monitor
# REQUIRED. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Panel ------------------------------------------------------------------
# Container image. Override to pin a specific version or use a fork.
PANEL_IMAGE=ghcr.io/BlackLuny/server-monitor-panel:latest

# REQUIRED. Secret used to sign session JWTs. At least 32 bytes.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Logging.
LOG_FILTER=info,sqlx=warn
LOG_FORMAT=text

# GitHub update feed — public repo, anonymous works; set a PAT for higher rate limit.
GITHUB_REPO=BlackLuny/server-monitor-rs
GITHUB_TOKEN=

# --- Port bindings ----------------------------------------------------------
# Keep HTTP on loopback when Caddy fronts this deployment.
PANEL_HTTP_BIND=127.0.0.1
# gRPC port agents connect to. "0.0.0.0" exposes it, "127.0.0.1" keeps it
# internal when Caddy terminates TLS and proxies /grpc/*.
PANEL_GRPC_BIND=0.0.0.0

# --- Caddy (optional, enabled via `--profile caddy`) ------------------------
# Public domain for TLS + HTTPS.
DOMAIN=panel.example.com
